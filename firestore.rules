rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helper
    function isAuth() {
      return request.auth != null;
    }
    
    // 1. Users Collection — Only authenticated users can read/write
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }
    
    // 2. RMAs Collection
    match /rmas/{rmaId} {
      // Public: read a single document by ID (for customer tracking)
      allow get: if true;
      
      // Public: allow limited list queries (max 10 results)
      // App-level code enforces exact-match search — no partial queries sent
      allow list: if isAuth() || request.query.limit <= 10;
      
      // Staff: update and delete
      allow update, delete: if isAuth();
      
      // Creation: Staff OR public guest submit (with restrictions)
      allow create: if isAuth() || (
        request.resource.data.status == 'PENDING' &&
        request.resource.data.createdBy == 'Customer (Web)'
      );
    }
    
    // 3. Config/Master Data — public read, staff write
    match /brands/{d} { allow read: if true; allow write: if isAuth(); }
    match /distributors/{d} { allow read: if true; allow write: if isAuth(); }
    match /settings/{d} { allow read: if true; allow write: if isAuth(); }
  }
}
