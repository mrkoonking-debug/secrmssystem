rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth Helper
    function isAuth() {
      return request.auth != null;
    }

    // Admin Helper — checks role from Firestore users collection
    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // 1. Users Collection — read: any authenticated, write: admin only
    match /users/{userId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    
    // 2. RMAs Collection
    match /rmas/{rmaId} {
      // Public: read a single document by ID (for customer tracking page)
      // NOTE: This exposes all fields including PII. Consider moving
      // sensitive fields (devicePassword, customerEmail) to a subcollection
      // /rmas/{rmaId}/private/{doc} with isAuth() read rules in the future.
      allow get: if true;
      
      // List: authenticated staff only, OR limited public queries (max 5 results)
      // Public list is needed for searchRMAsPublic (where queries on quotationNumber, serialNumber, groupRequestId)
      allow list: if isAuth() || request.query.limit <= 5;
      
      // Update and delete: authenticated staff only
      allow update, delete: if isAuth();
      
      // Creation: Staff OR public guest submit (with strict restrictions)
      allow create: if isAuth() || (
        request.resource.data.status == 'PENDING' &&
        request.resource.data.createdBy == 'Customer (Web)' &&
        // Prevent guest from setting admin-only fields
        !('serviceType' in request.resource.data) &&
        !('resolution' in request.resource.data) &&
        !('repairCosts' in request.resource.data)
      );
    }
    
    // 3. Config/Master Data — public read, admin write
    match /brands/{d} { allow read: if true; allow write: if isAdmin(); }
    match /distributors/{d} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{d} { allow read: if true; allow write: if isAdmin(); }
    
    // 4. Counters — authenticated only (used for sequential Job ID generation)
    match /counters/{d} { allow read, write: if isAuth(); }
  }
}
